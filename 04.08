---

[ 인증키 생성 법]

SSLCertificateFile /etc/ssl/server-cert.pem   (공개)
SSLCertificateKeyFile /etc/ssl/server-key.pem  (개인)
 #systemctl restart httpd

1. cd /etc/ssl/ 자체 CA 키 + 인증서 생성
가. CA 개인키
     #openssl genrsa -out ca-key.pem 4096

      나. CA 인증서 (루트 CA)
           #openssl req -x509 -new -key ca-key.pem -sha256 -days 3650 -out ca.pem \-subj                              "/C=KR/ST=Daegu/L=Daegu/O=Security/OU=RootCA/CN=Roror Root CA"

  2. #vi /etc/ssl/openssl-san.cnf  //밑의 내용 붙혀넣기

[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
req_extensions     = req_ext
distinguished_name = dn

[ dn ]
C  = KR
ST = Daegu
L  = Daegu
O  = Roror Company
OU = Sec
CN = [roror.co.kr](http://roror.co.kr/)

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = [roror.co.kr](http://roror.co.kr/)
DNS.2 = [www.roror.co.kr](http://www.roror.co.kr/)
DNS.3 = [mail.roror.co.kr](http://mail.roror.co.kr/)

1. 서버키 생성
#openssl genrsa -out server-key.pem 2048

 4 . CSR 생성 명령어
      #openssl req -new -key server-key.pem -out server.csr -config openssl-san.cnf

1. 인증서 서명

     #openssl x509 -req -in server.csr -CA ca.pem -CAkey ca-key.pem -CAcreateserial \-
     out server-cert.pem -days 825 -sha256 \
    -extfile openssl-san.cnf -extensions req_ext

    #openssl x509 -in server-cert.pem -text -noout | grep -A 1 "Subject Alternative Name"

