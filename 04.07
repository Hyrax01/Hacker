# audit2why < /var/log/audit/audit.log                                           ///var/log/audit/audit.log 파일을 읽고, 왜 SELinux가 특정 동작을 차단했는지 사람이 이해할 수 있는 형태로 설명해 줌 (디버깅 도구)
root@roror:/var/www/html/pentest# setsebool -P httpd_can_network_connect 1       //Apache가 외부 네트워크 접속 허용 (curl, API 요청 등)
root@roror:/var/www/html/pentest# setsebool -P httpd_can_network_connect_db 1    //Apache가 DB 접속 허용 (PHP에서 MySQL/MariaDB 접속 가능)

