mysql_secure_installation = mariadb-secure-installation
$mysql 누르면 ls랑 비슷한 명령어 = show databases;

---

2.#mysql
> show database;  (데이터베이스 목록 출력)
> use mysql  (데이터베이스 이동)
> show tables;  (테이블 목록 출력)
> describe user;  (테이블 구조)
> SELECT Host, User, Password FROM user;
> describe db;
> SELECT host, user, db FROM db;

-데이터 베이스 생성
> create database pentest;  (이름이 pentest 인 데이터베이스 생성)
> use pentest;
> show tables;

-사용자 생성 및 권한(데이터베이스) 부여
> grant all privileges on pentest.* to 'roror'@'localhost' identified by 'password';
> flush privileges;
1) database 이름 : pentest
2) hostname : localhost
3) user : roror
4) password : password
5) 권한 : all privileges

-위에서 생성한 사용자 DB권한 출력
> use mysql
> SELECT Host, User, password FROM user;
> SELECT host, user, db FROM db;

- 위에서 생성한 사용자 삭제
> drop user roror@localhost;
> flush privileges;
